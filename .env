# ── Supabase ──────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_STORAGE_BUCKET=backups
SUPABASE_IMMUTABLE_BUCKET=immutable-backups

# ── Database ───────────────────────────────────────
LOCAL_DB_PATH=%LocalAppData%\ProManSystem\app.db
SHADOW_DB_PATH=D:\Backup\ProManSystem\shadow.db

# ── Encryption ─────────────────────────────────────
BACKUP_ENCRYPTION_ENABLED=true
SALT_STORAGE_METHOD=WindowsCredentialManager

# ── Sync Settings ──────────────────────────────────
SYNC_INTERVAL_SECONDS=30
PING_INTERVAL_HOURS=24
BACKUP_RETENTION_COUNT=30
BACKUP_MIN_SIZE_RATIO=0.70
BACKUP_GUARD_THRESHOLD=0.20

# ── Web Dashboard ──────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
VERCEL_PROJECT_NAME=syncvault-dashboard

# ── GitHub Actions ─────────────────────────────────
GITHUB_ACTIONS_PING_CRON=0 8 * * *

# ── Device ─────────────────────────────────────────
DEVICE_ID=PC-MOUNIR-MAIN
DEVICE_NAME=PC Principal
